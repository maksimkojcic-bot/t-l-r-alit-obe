# Copy this file to .env and fill locally.
# Never paste real API keys into chat or README files.

# Google AI Studio / Gemini API
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image
GEMINI_VIDEO_MODEL=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
VOICE_HOST=
VOICE_COACH=
VOICE_CANDIDATE_1=
VOICE_CANDIDATE_2=
VOICE_CANDIDATE_3=
VOICE_CANDIDATE_4=
VOICE_CANDIDATE_5=

# TikTok official Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8765/callback
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# Production controls
DAILY_VIDEO_TARGET=1
MAX_GOOGLE_AI_MONTHLY_BUDGET_EUR=30
REQUIRE_MANUAL_REVIEW=true
